{
  "expo": {
    "name": "Straytopia",
    "slug": "straytopia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "straytopia",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFCEF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.straytopia.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFCEF"
      },
      "package": "com.straytopia.app"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Straytopia to save precise report and proof locations for operations review only."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Straytopia to attach report and proof photos for operations review.",
          "cameraPermission": "Allow Straytopia to capture report and proof photos."
        }
      ]
    ],
    "newArchEnabled": true
  }
}
